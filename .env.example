# Spielgarten - deployment settings for `docker compose`.
# Copy this file to `.env` and adjust as needed:  cp .env.example .env
#
# The app is a static, no-backend PWA - it has no runtime secrets.
# These values only control how the container is run.

# Published image tag to run: latest | edge | a pinned version such as 0.0.1
IMAGE_TAG=latest

# Host port the app is served on (the container always listens on 8080).
HOST_PORT=8080
